# Zoho OAuth credentials (from https://api-console.zoho.com/)
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_REDIRECT_URI=http://localhost:8501
# Zoho datacenter domain — check your API Console URL:
#   api-console.zoho.com  → .com (US)
#   api-console.zoho.in   → .in  (India)
#   api-console.zoho.eu   → .eu  (Europe)
#   api-console.zoho.com.au → .com.au (Australia)
ZOHO_DOMAIN=.com

# Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Gemini model — choose based on your free tier limits:
#   gemini-2.5-flash-lite         → stable, 10 RPM, 20 RPD
#   gemini-3.1-flash-lite-preview → preview, 15 RPM, 500 RPD (recommended for free tier)
#   gemini-2.5-flash              → stable, 5 RPM, 20 RPD
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# LLM provider: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# OpenAI API key (optional — only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
